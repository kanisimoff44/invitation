# Скопируйте в .env и заполните значения. .env НЕ коммитится в git.

APP_ENV=production

# DATABASE_URL можно не задавать — по умолчанию используется
# <корень проекта>/data/invitation.db (в контейнере это /app/data, куда
# монтируется volume). Переопределяйте, только если нужна другая СУБД.
# DATABASE_URL=sqlite:////app/data/invitation.db

# --- Google Sheets (необязательно) ------------------------------------
# Оставьте пустыми, если интеграция не нужна — приложение будет работать
# и сохранять ответы только в БД.
# Путь к JSON-ключу сервис-аккаунта ВНУТРИ контейнера (см. volume secrets/).
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/google-service-account.json
# ID таблицы из URL: .../spreadsheets/d/<ЭТОТ_ID>/edit
GOOGLE_SHEET_ID=
# Название листа, куда писать ответы (создастся автоматически, если нет).
GOOGLE_SHEET_WORKSHEET=RSVP

# --- Поведение формы --------------------------------------------------
# Показывать поле "количество гостей" (+1/+2). true/false.
ENABLE_GUESTS_COUNT_FIELD=true

# --- Домен и HTTPS ----------------------------------------------------
# Разрешённые Host-заголовки (через запятую). Домен вашего сайта.
ALLOWED_HOSTS=example.com,www.example.com

# Домен для nginx и выпуска сертификата (без https://, без слэша).
DOMAIN=example.com
# Email для регистрации в Let's Encrypt (уведомления об истечении сертификата).
CERTBOT_EMAIL=you@example.com
